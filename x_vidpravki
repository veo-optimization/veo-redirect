function calcOrderSum(orders){
  return orders.reduce((a,o)=>a+o.products.reduce((b,p)=>b+p.price*p.qty,0),0);
}
function calcOrderQty(orders){
  return orders.reduce((a,o)=>a+o.products.reduce((b,p)=>b+p.qty,0),0);
}
