function populateClientDrop(){
  const opts=document.getElementById('clientDropOpts');
  const cIds=[...new Set(SHIPMENTS.map(s=>s.cId))].sort((a,b)=>CLIENTS[a].name.localeCompare(CLIENTS[b].name,'uk'));
  opts.innerHTML=`<div class="chip-drop-item ${chipClientVal===''?'selected':''}" onclick="setClientFilter('','Клієнт')">Всі клієнти</div>`
