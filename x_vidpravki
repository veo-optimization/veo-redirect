// ═══════════════════════════════════════════════
// PAY BLOCK
// ═══════════════════════════════════════════════
function buildPayBlock(s,ords){
  const base=`<div class="ant-desc"><div class="ant-desc-item"><label>Метод</label><span>${s.payMethod}</span></div></div>`;
  if(s.payStatus==='paid')
    return `<div class="ant-alert ant-alert-success">✅&nbsp;Оплачено повністю&nbsp;·&nbsp;${s.payMethod}</div>`;
  if(s.payStatus==='refunded')
    return `<div class="ant-alert ant-alert-warning">↩️&nbsp;Кошти повернуто клієнту</div>`;
  if(s.payStatus==='cod_pending')
    return `<div class="ant-alert ant-alert-info">📦&nbsp;Накладений платіж — в дорозі.<br><span style="font-size:12px;display:block;margin-top:4px">Після отримання на НП статус оновиться на "Оплачено повністю".</span></div>`;
  if(s.payStatus==='unpaid')
    return `<div class="ant-alert ant-alert-error">❌&nbsp;Не оплачено&nbsp;·&nbsp;${s.payMethod}</div>`;
  if(s.payStatus==='await_prepay'){
    const received=s.prepayRec||0;
    const needed=s.prepay||200;
    const pct=received>=needed?100:Math.round((received/needed)*100);
    const ok=received>=needed;
    // show per-order payment status
    const ordPayHtml=ords.map((o,i)=>{
      const oSum=o.products.reduce((a,p)=>a+p.price*p.qty,0);
      let payLbl,payCls;
      if(i===0){payLbl='Оплачено (IBAN)';payCls='val-paid';}
      else if(i===1){payLbl=`Передплата ${needed} ₴ / IBAN`;payCls='val-await';}
      else{payLbl='Відкладений платіж';payCls='val-await';}
      return `<div class="pay-order-row"><span>${o.id}</span><span style="font-family:var(--mono)">${oSum.toLocaleString()}&nbsp;₴</span><span class="${payLbl.includes('Оплач')?'val-paid':'val-await'}" style="font-size:12px">${payLbl}</span></div>`;
    }).join('');
    return `<div class="pay-card">
      <div class="pay-row">
        <span style="font-weight:600;font-size:13px">Передплата&nbsp;${needed}&nbsp;₴</span>
        <span class="ant-tag ${ok?'tag-paid':'tag-await'}">${ok?'Передплату отримано':'Очікує передплату'}</span>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--sub);margin-bottom:4px">
        <span>Отримано:&nbsp;<b style="color:var(--tx)">${received}&nbsp;₴</b></span>
        <span>Потрібно:&nbsp;<b style="color:var(--tx)">${needed}&nbsp;₴</b></span>
      </div>
      <div class="pay-progress"><div class="pay-fill" style="width:${pct}%;background:${ok?'var(--green)':'var(--yellow)'}"></div></div>
      ${ok
        ?`<div class="ant-alert ant-alert-success" style="margin:6px 0 0">✅&nbsp;Передплату отримано. Можна формувати ТТН.</div>`
        :`<div class="pay-note">⚠&nbsp;ТТН формується після надходження ${needed}&nbsp;₴</div>
          <button class="ant-btn ant-btn-default ant-btn-sm" style="margin-top:8px" onclick="confirmPrepay('${s.id}')">✓&nbsp;Підтвердити отримання ${needed}&nbsp;₴</button>`
      }
      ${ordPayHtml?`<div style="margin-top:10px;border-top:1px solid var(--brd);padding-top:8px"><div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px">Деталі по замовленнях</div>${ordPayHtml}</div>`:''}
      <div class="ant-desc" style="margin-top:8px">
        <div class="ant-desc-item"><label>Метод</label><span>${s.payMethod}</span></div>
        <div class="ant-desc-item"><label>Залишок накладений</label><span class="mono">${(s.goodsSum+s.deliveryCost-received).toLocaleString()}&nbsp;₴</span></div>
      </div>
    </div>`;
  }
  return base;
}

// ═══════════════════════════════════════════════
// DRAWER FOOTER
// ═══════════════════════════════════════════════
function buildDrawerFooter(s){
  const foot=document.getElementById('drawerFooter');
  const canForm=s.payStatus==='paid'
    ||(s.payStatus==='await_prepay'&&s.prepayRec>=s.prepay)
    ||s.payStatus==='cod_pending'||s.payStatus==='unpaid';

  if(s.status==='unformed'||s.status==='deferred'){
    foot.innerHTML=`
      <div class="dfr">
        <button class="ant-btn ant-btn-primary" style="flex:2" onclick="doFormTTN('${s.id}')" ${!canForm?'disabled':''}>
          📋&nbsp;${canForm?'Сформувати ТТН':'ТТН (очікує передплату)'}
        </button>
        <button class="ant-btn ant-btn-default" onclick="printS()">🖨</button>
        <button class="ant-btn ant-btn-default" onclick="openDeferFor('${s.id}')">📅&nbsp;Відкласти</button>
      </div>
      <div class="dfr">
        <button class="ant-btn ant-btn-danger" style="flex:1" onclick="doIgnore('${s.id}')">🚫&nbsp;Ігнорувати</button>
      </div>`;
  } else if(s.status==='formed'){
    foot.innerHTML=`
      <div class="dfr">
        <button class="ant-btn ant-btn-success" style="flex:2" onclick="doSent('${s.id}')">✈️&nbsp;Відправлено</button>
        <button class="ant-btn ant-btn-default" onclick="printS()">🖨&nbsp;Друк</button>
      </div>`;
  } else if(s.status==='sent'||s.status==='transit'){
    foot.innerHTML=`
      <div class="dfr">
        <button class="ant-btn ant-btn-success" style="flex:1" onclick="doReceived('${s.id}')">✅&nbsp;Отримано</button>
        <button class="ant-btn ant-btn-danger" style="flex:1" onclick="doChange('${s.id}','returned')">↩️&nbsp;Повернення</button>
      </div>`;
  } else {
    foot.innerHTML=`<div class="dfr"><button class="ant-btn ant-btn-default" onclick="printS()">🖨&nbsp;Роздрукувати</button></div>`;
  }
}

