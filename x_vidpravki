<!DOCTYPE html>

<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Відправки — CRM Beroo</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/antd/5.14.1/reset.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0F1117;--surface:#161B27;--s2:#1C2235;--s3:#222840;
  --brd:#2C3451;--brd2:#374060;
  --tx:#E2E5F0;--sub:#7B84A0;--muted:#4A5068;
  --acc:#1677FF;--acc2:#0958D9;
  --yellow:#FAAD14;--yb:rgba(250,173,20,.13);--ybrd:rgba(250,173,20,.35);
  --blue:#4096FF;--bb:rgba(64,150,255,.13);--bbrd:rgba(64,150,255,.35);
  --violet:#9254DE;--vb:rgba(146,84,222,.13);--vbrd:rgba(146,84,222,.35);
  --orange:#FA8C16;--ob:rgba(250,140,22,.13);--obrd:rgba(250,140,22,.35);
  --green:#52C41A;--gb:rgba(82,196,26,.13);--gbrd:rgba(82,196,26,.35);
  --red:#FF4D4F;--rb:rgba(255,77,79,.13);--rbrd:rgba(255,77,79,.35);
  --gray:#8C8C8C;--grayb:rgba(140,140,140,.1);--graybrd:rgba(140,140,140,.25);
  --teal:#13C2C2;--tealb:rgba(19,194,194,.13);--tealbrd:rgba(19,194,194,.3);
  --font:'DM Sans',sans-serif;--mono:'JetBrains Mono',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px;background:var(--bg);color:var(--tx)}
body{font-family:var(--font);background:var(--bg);color:var(--tx);min-height:100vh;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--brd2);border-radius:3px}

/* LAYOUT */
.shell{display:flex;flex-direction:column;height:100vh;overflow:hidden}
.page{flex:1;display:flex;flex-direction:column;overflow:hidden;min-height:0}

/* TOP NAV */
.top-nav{height:52px;background:var(–surface);border-bottom:1px solid var(–brd);display:flex;align-items:center;padding:0 24px;gap:0;flex-shrink:0;z-index:20}
.logo{font-size:15px;font-weight:700;letter-spacing:-.3px;display:flex;align-items:center;gap:8px;margin-right:32px;color:var(–tx)}
.logo-mark{width:26px;height:26px;background:var(–acc);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:#fff}
.nav-menu{display:flex;height:100%;align-items:flex-end}
.nav-item{padding:0 16px;height:100%;display:flex;align-items:center;font-size:13.5px;font-weight:500;color:var(–sub);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap;user-select:none}
.nav-item:hover{color:var(–tx)}
.nav-item.active{color:var(–tx);border-bottom-color:var(–acc)}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:6px;flex-shrink:0}
.avatar{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(–acc),#7C3AED);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;cursor:pointer;color:#fff;flex-shrink:0}

/* PAGE */

/* TOOLBAR */
.toolbar{padding:10px 16px 8px;background:var(–surface);border-bottom:1px solid var(–brd);flex-shrink:0}
.toolbar-top{display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap}
.page-title{font-size:16px;font-weight:700;letter-spacing:-.3px}
.toolbar-actions{display:flex;gap:6px;margin-left:auto;flex-wrap:wrap}
/* FILTER ROW */
.filter-row{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.filter-chip{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:6px;border:1px solid var(–brd);background:var(–s3);font-size:12.5px;font-weight:500;color:var(–sub);cursor:pointer;transition:all .15s;white-space:nowrap;user-select:none}
.filter-chip:hover{border-color:var(–acc);color:var(–acc)}
.filter-chip.active{border-color:var(–acc);background:rgba(22,119,255,.12);color:var(–acc);font-weight:600}
.filter-chip .fc-dot{width:5px;height:5px;border-radius:50%;background:var(–acc);display:none}
.filter-chip.active .fc-dot{display:inline-block}
/* compact select */
.ant-select{background:var(–s3);border:1px solid var(–brd);border-radius:6px;padding:4px 8px;font-family:var(–font);font-size:12.5px;color:var(–sub);outline:none;cursor:pointer;appearance:none}
.ant-select:focus{border-color:var(–acc)}
/* SYNC PILL in topbar */
.sync-pill{display:flex;align-items:center;gap:5px;padding:3px 8px 3px 6px;border-radius:20px;background:var(–s2);border:1px solid var(–brd);cursor:pointer;transition:all .2s;user-select:none}
.sync-pill:hover{border-color:var(–gbrd)}
.sync-pill-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;transition:background .3s}
.sync-pill-txt{font-size:11px;color:var(–sub);font-family:var(–mono);transition:all .2s}
/* BULK ACTIONS BAR */
.bulk-bar{display:none;align-items:center;gap:6px;padding:7px 16px;background:var(–s2);border-bottom:1px solid var(–brd);flex-shrink:0;flex-wrap:wrap;animation:slideDown .18s ease}
.bulk-bar.open{display:flex}
@keyframes slideDown{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}
.bulk-sel-cnt{font-size:12.5px;font-weight:600;color:var(–tx);margin-right:4px}
.ant-btn{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:6px;font-family:var(–font);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;border:1px solid transparent;line-height:1.4;white-space:nowrap}
.ant-btn-primary{background:var(–acc);color:#fff;border-color:var(–acc)}
.ant-btn-primary:hover{background:var(–acc2);border-color:var(–acc2)}
.ant-btn-primary:disabled{opacity:.45;cursor:not-allowed}
.ant-btn-default{background:transparent;color:var(–tx);border-color:var(–brd2)}
.ant-btn-default:hover{border-color:var(–acc);color:var(–acc)}
.ant-btn-danger{background:transparent;color:var(–red);border-color:var(–rbrd)}
.ant-btn-danger:hover{background:var(–rb)}
.ant-btn-success{background:transparent;color:var(–green);border-color:var(–gbrd)}
.ant-btn-success:hover{background:var(–gb)}
.ant-btn-sm{padding:3px 8px;font-size:12px}
.ant-btn-icon{padding:5px;min-width:28px;justify-content:center}

.toolbar-filters{display:flex;gap:8px;flex-wrap:wrap}
.search-box{position:relative;min-width:180px;max-width:260px;flex:1}
.search-box svg{position:absolute;left:9px;top:50%;transform:translateY(-50%);color:var(–muted);pointer-events:none}
.search-box input{width:100%;background:var(–s3);border:1px solid var(–brd);border-radius:6px;padding:5px 10px 5px 30px;font-family:var(–font);font-size:13px;color:var(–tx);outline:none;transition:border-color .15s}
.search-box input:focus{border-color:var(–acc)}
.search-box input::placeholder{color:var(–muted)}
.ant-select{background:var(–s3);border:1px solid var(–brd);border-radius:6px;padding:5px 10px;font-family:var(–font);font-size:13px;color:var(–sub);outline:none;cursor:pointer;appearance:none;min-width:130px}
.ant-select:focus{border-color:var(–acc)}

/* STATUS TABS — sticky, always visible */
.status-tabs{display:flex;gap:0;overflow-x:auto;background:var(–surface);border-bottom:1px solid var(–brd);flex-shrink:0;scrollbar-width:none;position:sticky;top:0;z-index:30}
.status-tabs::-webkit-scrollbar{display:none}
.stab{padding:8px 12px;font-size:12px;font-weight:500;color:var(–sub);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all .15s;display:flex;align-items:center;gap:4px;user-select:none;flex-shrink:0}
.stab:hover{color:var(–tx)}
.stab.active{color:var(–tx);border-bottom-color:var(–acc)}
.stab-cnt{background:var(–s3);color:var(–sub);font-size:10px;font-weight:700;border-radius:20px;padding:1px 6px;font-family:var(–mono)}
.stab.active .stab-cnt{background:var(–acc);color:#fff}

/* ANT TAG */
.ant-tag{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:4px;font-size:12px;font-weight:500;border:1px solid transparent;white-space:nowrap}
.ant-tag::before{content:’’;width:5px;height:5px;border-radius:50%;flex-shrink:0}
.tag-unformed{background:var(–yb);color:var(–yellow);border-color:var(–ybrd)}.tag-unformed::before{background:var(–yellow)}
.tag-formed{background:var(–bb);color:var(–blue);border-color:var(–bbrd)}.tag-formed::before{background:var(–blue)}
.tag-sent{background:var(–vb);color:var(–violet);border-color:var(–vbrd)}.tag-sent::before{background:var(–violet)}
.tag-transit{background:var(–ob);color:var(–orange);border-color:var(–obrd)}.tag-transit::before{background:var(–orange)}
.tag-received{background:var(–gb);color:var(–green);border-color:var(–gbrd)}.tag-received::before{background:var(–green)}
.tag-returned{background:var(–rb);color:var(–red);border-color:var(–rbrd)}.tag-returned::before{background:var(–red)}
.tag-ignored{background:var(–grayb);color:var(–gray);border-color:var(–graybrd)}.tag-ignored::before{background:var(–gray)}
.tag-deferred{background:var(–tealb);color:var(–teal);border-color:var(–tealbrd)}.tag-deferred::before{background:var(–teal)}
.tag-paid{background:var(–gb);color:var(–green);border-color:var(–gbrd)}
.tag-await{background:var(–yb);color:var(–yellow);border-color:var(–ybrd)}
.tag-partial{background:var(–ob);color:var(–orange);border-color:var(–obrd)}
.tag-unpaid{background:var(–rb);color:var(–red);border-color:var(–rbrd)}
.tag-cod{background:var(–bb);color:var(–blue);border-color:var(–bbrd)}

/* TABLE AREA */
.table-area{flex:1;overflow-y:auto;overflow-x:auto;padding:0;min-height:0;-webkit-overflow-scrolling:touch}

/* DESKTOP TABLE */
.data-table{width:100%;border-collapse:separate;border-spacing:0;font-size:13px;min-width:900px}
.data-table th{padding:9px 12px;text-align:left;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(–muted);border-bottom:1px solid var(–brd);position:sticky;top:0;background:var(–bg);z-index:2;white-space:nowrap;user-select:none}
.data-table td{padding:10px 12px;border-bottom:1px solid var(–brd);vertical-align:middle}
.data-table tbody tr:hover td{background:var(–s2);cursor:pointer}
.data-table tbody tr.urgent-row td{background:rgba(250,173,20,.04)}
.data-table tbody tr:last-child td{border-bottom:none}
/* SELECT COL */
.data-table th:first-child,.data-table td:first-child{width:36px;padding:10px 6px 10px 16px}
.row-chk{width:16px;height:16px;accent-color:var(–acc);cursor:pointer}

/* CLIENT CELL */
.cc{display:flex;align-items:center;gap:8px}
.cc-av{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(–acc),#7C3AED);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;flex-shrink:0}
.cc-name{font-weight:600;color:var(–tx);font-size:13px}
.cc-sub{font-size:11px;color:var(–muted);display:flex;align-items:center;gap:4px;margin-top:1px}
.addr-badge{font-size:10px;background:var(–s3);border:1px solid var(–brd);border-radius:4px;padding:0px 5px;color:var(–sub);font-family:var(–mono)}

/* TTN CELL */
.ttn-box{font-family:var(–mono);font-size:12px;color:var(–sub);display:inline-flex;align-items:center;gap:2px}
.ttn-main{color:var(–sub)}
.ttn-last{color:var(–tx);border:1px solid var(–brd2);border-radius:4px;padding:1px 5px;background:var(–s2);font-weight:600}
.ttn-empty{color:var(–muted);font-style:italic;font-size:12px}

/* AMOUNT */
.amount{font-weight:700;font-family:var(–mono);color:var(–tx)}

/* ROW ACTIONS */
.row-acts{display:flex;gap:4px;opacity:0;transition:opacity .15s}
.data-table tbody tr:hover .row-acts{opacity:1}

/* SUMMARY BAR */
.sum-bar{display:flex;gap:20px;padding:8px 20px;background:var(–surface);border-top:1px solid var(–brd);flex-shrink:0;overflow-x:auto;scrollbar-width:none;align-items:center}
.sum-bar::-webkit-scrollbar{display:none}
.sum-i{display:flex;align-items:center;gap:6px;white-space:nowrap}
.sum-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.sum-lbl{font-size:12px;color:var(–sub)}
.sum-v{font-size:12.5px;font-weight:700;font-family:var(–mono)}

/* MOBILE CARDS */
.cards-wrap{display:none;flex-direction:column;gap:8px;padding:12px}
.m-card{background:var(–surface);border:1px solid var(–brd);border-radius:8px;padding:14px;cursor:pointer;transition:all .15s;position:relative;overflow:hidden}
.m-card::before{content:’’;position:absolute;left:0;top:0;bottom:0;width:3px}
.m-card.unformed::before{background:var(–yellow)}
.m-card.formed::before{background:var(–blue)}
.m-card.sent::before{background:var(–violet)}
.m-card.transit::before{background:var(–orange)}
.m-card.received::before{background:var(–green)}
.m-card.returned::before{background:var(–red)}
.m-card.ignored::before{background:var(–gray)}
.m-card.deferred::before{background:var(–teal)}
.m-card:hover{background:var(–s2);border-color:var(–brd2)}
.mc-h{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.mc-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px 16px;margin-bottom:10px}
.mc-f label{font-size:11px;color:var(–muted);display:block;margin-bottom:1px}
.mc-f span{font-size:13px;font-weight:500}
.mc-bot{display:flex;align-items:center;justify-content:space-between}

/* EMPTY STATE */
.empty-st{text-align:center;padding:60px 20px;color:var(–sub)}
.empty-st h3{font-size:15px;font-weight:600;color:var(–tx);margin-bottom:6px;margin-top:12px}

/* DRAWER */
.drawer-mask{position:fixed;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(3px);z-index:100;opacity:0;pointer-events:none;transition:opacity .25s}
.drawer-mask.open{opacity:1;pointer-events:all}
.drawer{position:fixed;right:0;top:0;bottom:0;width:480px;max-width:100vw;background:var(–surface);border-left:1px solid var(–brd);z-index:101;transform:translateX(100%);transition:transform .3s cubic-bezier(.32,1,.46,1);display:flex;flex-direction:column;overflow:hidden}
.drawer.open{transform:translateX(0)}
.drawer-hd{padding:16px 20px;border-bottom:1px solid var(–brd);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.drawer-hd-left{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.drawer-title{font-size:15px;font-weight:700}
.drawer-close{width:30px;height:30px;border-radius:6px;border:1px solid var(–brd2);background:transparent;color:var(–sub);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.drawer-close:hover{background:var(–s3);color:var(–tx)}
.drawer-body{flex:1;overflow-y:auto;padding:20px}
.drawer-footer{padding:14px 20px;border-top:1px solid var(–brd);flex-shrink:0;display:flex;flex-direction:column;gap:8px}
.dfr{display:flex;gap:8px}

/* SECTIONS */
.sec-hd{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(–muted);margin:18px 0 10px;display:flex;align-items:center;gap:8px}
.sec-hd:first-child{margin-top:0}
.sec-hd::after{content:’’;flex:1;height:1px;background:var(–brd)}

/* ANT DESC */
.ant-desc{display:grid;grid-template-columns:1fr 1fr;gap:10px;background:var(–s2);border:1px solid var(–brd);border-radius:8px;padding:12px}
.ant-desc.full{grid-template-columns:1fr}
.ant-desc-item label{font-size:11px;color:var(–muted);display:block;margin-bottom:3px}
.ant-desc-item span{font-size:13px;font-weight:500;word-break:break-word}
.mono{font-family:var(–mono);font-size:12px}

/* ANT ALERT */
.ant-alert{border-radius:6px;padding:9px 12px;font-size:13px;border:1px solid transparent;margin:8px 0}
.ant-alert-warning{background:var(–yb);border-color:var(–ybrd);color:var(–yellow)}
.ant-alert-success{background:var(–gb);border-color:var(–gbrd);color:var(–green)}
.ant-alert-info{background:var(–bb);border-color:var(–bbrd);color:var(–blue)}
.ant-alert-error{background:var(–rb);border-color:var(–rbrd);color:var(–red)}
.ant-alert-teal{background:var(–tealb);border-color:var(–tealbrd);color:var(–teal)}

/* PAY BLOCK */
.pay-card{background:var(–s2);border:1px solid var(–brd);border-radius:8px;padding:12px;margin:0}
.pay-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.pay-progress{height:5px;background:var(–s3);border-radius:3px;overflow:hidden;margin:6px 0}
.pay-fill{height:100%;border-radius:3px;transition:width .4s}
.pay-note{font-size:12px;color:var(–yellow);margin-top:6px}
.pay-order-row{display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(–brd);font-size:13px}
.pay-order-row:last-child{border-bottom:none}

/* COLLAPSE */
.ant-collapse{border:1px solid var(–brd);border-radius:8px;overflow:hidden;margin-bottom:8px}
.ant-collapse-hd{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;cursor:pointer;background:var(–s2);transition:background .15s;user-select:none}
.ant-collapse-hd:hover{background:var(–s3)}
.ant-collapse-arrow{transition:transform .2s;color:var(–sub);flex-shrink:0}
.ant-collapse-arrow.open{transform:rotate(90deg)}
.ant-collapse-body{background:var(–bg);border-top:1px solid var(–brd);overflow:hidden;max-height:0;transition:max-height .3s ease}
.ant-collapse-body.open{max-height:600px}

/* PRODUCT ROW */
.prod-row{display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid var(–brd)}
.prod-row:last-child{border-bottom:none}
.prod-thumb{width:40px;height:40px;border-radius:6px;background:var(–s2);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.prod-info{flex:1;min-width:0}
.prod-name{font-size:13px;font-weight:600;margin-bottom:2px;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.prod-link{font-size:11px;color:var(–acc);text-decoration:none;padding:1px 5px;border:1px solid var(–bbrd);border-radius:3px;background:var(–bb);font-family:var(–mono)}
.prod-link:hover{background:var(–bb);opacity:.8}
.prod-meta{font-size:12px;color:var(–sub)}
.prod-price{text-align:right;flex-shrink:0}
.prod-price .unit{font-size:11px;color:var(–muted)}
.prod-price .total{font-size:13px;font-weight:700;font-family:var(–mono)}

/* DELIVERY COST */
.del-cost{display:flex;align-items:center;justify-content:space-between;padding:8px 14px;background:var(–s3);border-top:1px solid var(–brd);font-size:12px;color:var(–sub)}
.del-cost span:last-child{font-weight:600;color:var(–orange);font-family:var(–mono)}

/* TOTAL */
.total-card{background:var(–s2);border:1px solid var(–brd);border-radius:8px;padding:12px 14px;display:flex;align-items:center;justify-content:space-between;margin-top:12px}
.total-lbl{font-size:13px;color:var(–sub)}
.total-val{font-size:20px;font-weight:700;font-family:var(–mono);color:var(–green)}

/* CLIENT POPUP */
.cpopup-wrap{position:fixed;inset:0;z-index:300;pointer-events:none}
.cpopup{position:absolute;background:var(–surface);border:1px solid var(–brd2);border-radius:10px;padding:14px;min-width:240px;box-shadow:0 12px 40px rgba(0,0,0,.5);pointer-events:all;animation:popIn .18s ease}
@keyframes popIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
.cpopup-name{font-size:14px;font-weight:700;margin-bottom:2px}
.cpopup-id{font-size:11px;color:var(–muted);font-family:var(–mono);margin-bottom:10px}
.clink{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(–brd);text-decoration:none;color:var(–tx);font-size:13px;transition:color .15s}
.clink:last-child{border-bottom:none;padding-bottom:0}
.clink:hover{color:var(–acc)}
.clink-ico{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.pay-summary-mini{margin-top:10px;padding-top:10px;border-top:1px solid var(–brd)}
.pay-mini-row{display:flex;justify-content:space-between;font-size:12px;padding:3px 0;gap:12px}
.pay-mini-row .lbl{color:var(–sub)}
.pay-mini-row .val{font-family:var(–mono);font-weight:600}
.val-paid{color:var(–green)}
.val-await{color:var(–yellow)}
.val-unpaid{color:var(–red)}

/* MODAL (defer / bulk ship) */
.modal-mask{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
.modal-mask.open{display:flex}
.modal-box{background:var(–surface);border:1px solid var(–brd2);border-radius:10px;padding:24px;min-width:320px;max-width:440px;width:100%;animation:popIn .2s ease}
.modal-title{font-size:16px;font-weight:700;margin-bottom:6px}
.modal-sub{font-size:13px;color:var(–sub);margin-bottom:18px}
.modal-footer{display:flex;gap:8px;justify-content:flex-end;margin-top:18px}
.ifield{background:var(–s3);border:1px solid var(–brd2);border-radius:6px;padding:7px 12px;font-family:var(–font);font-size:14px;color:var(–tx);outline:none;transition:border-color .15s;width:100%}
.ifield:focus{border-color:var(–acc)}
.ifield.sm{width:80px}
.ifield-row{display:flex;align-items:center;gap:10px}
.iunit{font-size:13px;color:var(–sub);white-space:nowrap}

/* BULK SHIP MODAL checkboxes */
.bulk-order-item{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(–brd);cursor:pointer}
.bulk-order-item:last-child{border-bottom:none}
.bulk-order-item input{width:16px;height:16px;accent-color:var(–acc);cursor:pointer;flex-shrink:0}
.bulk-item-info{flex:1}
.bulk-item-id{font-size:13px;font-weight:600}
.bulk-item-meta{font-size:12px;color:var(–sub)}

/* TOAST */
.toast-wrap{position:fixed;top:64px;right:20px;z-index:500;display:flex;flex-direction:column;gap:8px}
.toast{background:var(–surface);border:1px solid var(–brd2);border-radius:8px;padding:10px 16px;font-size:13px;font-weight:500;color:var(–tx);box-shadow:0 8px 32px rgba(0,0,0,.5);display:flex;align-items:center;gap:8px;animation:slideIn .22s ease;min-width:240px}
@keyframes slideIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}
.toast.success{border-color:var(–gbrd);color:var(–green)}
.toast.error{border-color:var(–rbrd);color:var(–red)}
.toast.warning{border-color:var(–ybrd);color:var(–yellow)}

/* STATUS SEP */
.status-sep{grid-column:1/-1;padding:6px 12px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(–muted);background:var(–s2);border-bottom:1px solid var(–brd)}

/* TELEGRAM NOTIFICATION */
.tg-notif{position:fixed;bottom:80px;right:20px;z-index:600;background:var(–surface);border:1px solid rgba(34,158,217,.4);border-radius:12px;padding:12px 14px;min-width:280px;max-width:340px;box-shadow:0 8px 32px rgba(0,0,0,.5);animation:slideIn .25s ease;display:flex;gap:10px;align-items:flex-start}
.tg-notif-ico{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#229ED9,#1a7db0);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.tg-notif-body{flex:1;min-width:0}
.tg-notif-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:3px}
.tg-notif-bot{font-size:11px;color:var(–sub)}
.tg-notif-msg{font-size:12.5px;color:var(–tx);line-height:1.45;margin-top:3px}
.tg-notif-time{font-size:10px;color:var(–muted);flex-shrink:0}
.tg-notif-label{font-size:11px;font-weight:700;color:#229ED9}
.notif-log-btn{font-size:11px;color:var(–acc);cursor:pointer;text-decoration:underline;margin-top:4px;display:inline-block}

/* ICON-ONLY CHIPS */
.icon-chip{padding:5px 8px;gap:3px}
.icon-chip span.fc-dot{margin-right:-2px}
/* STICKY layout: filter-row + status-tabs always visible */
.toolbar{padding:8px 16px 6px;flex-shrink:0}
.status-tabs{position:sticky;top:0;z-index:39}
/* Override: toolbar is sticky, status-tabs below it */
/* We achieve “filter row + status tabs always on top, rest scrolls” via
making the .page itself overflow, not the shell */
.sticky-top{flex-shrink:0;z-index:40;background:var(–surface)}
/* PRIORITY ROW */
.data-table tbody tr.priority-row td{background:rgba(250,140,22,.08)}
.data-table tbody tr.priority-row td:first-child{box-shadow:inset 3px 0 0 var(–orange)}
/* PRIORITY TAG */
.tag-priority{background:var(–ob);color:var(–orange);border:1.5px solid var(–obrd);font-weight:700}
.tag-priority::before{background:var(–orange)}
/* CHIP DROPDOWNS */
.chip-drop{position:absolute;top:calc(100% + 6px);left:0;min-width:200px;background:var(–surface);border:1px solid var(–brd2);border-radius:8px;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:100;display:none;overflow:hidden}
.chip-drop.open{display:block;animation:popIn .15s ease}
.chip-drop-search{padding:8px 10px;border-bottom:1px solid var(–brd)}
.chip-drop-search input{width:100%;background:var(–s3);border:1px solid var(–brd);border-radius:5px;padding:5px 8px;font-family:var(–font);font-size:12px;color:var(–tx);outline:none}
.chip-drop-opts{max-height:200px;overflow-y:auto}
.chip-drop-item{padding:8px 12px;font-size:13px;cursor:pointer;transition:background .12s;white-space:nowrap;display:flex;align-items:center;justify-content:space-between}
.chip-drop-item:hover{background:var(–s2)}
.chip-drop-item.selected{color:var(–acc);font-weight:600}
.chip-drop-item .cdi-cnt{font-size:11px;color:var(–muted);font-family:var(–mono)}
/* important row */
.data-table tbody tr.important-row td{background:rgba(250,173,20,.07)}
.data-table tbody tr.important-row td:first-child{box-shadow:inset 3px 0 0 var(–yellow)}

/* NP SYNC — pill in topbar */
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(–green);flex-shrink:0}
.sync-dot.pulse{animation:syncPulse 1.5s ease infinite}
.sync-dot.idle{background:var(–muted)}
.sync-dot.error{background:var(–red)}
@keyframes syncPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.8)}}
/* sync dropdown */
.sync-dropdown{position:absolute;top:calc(100% + 8px);right:0;width:320px;background:var(–surface);border:1px solid var(–brd2);border-radius:10px;padding:14px;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:200;display:none;animation:popIn .18s ease}
.sync-dropdown.open{display:block}
.sync-progress{height:4px;background:var(–brd);border-radius:2px;overflow:hidden;margin:8px 0 0}
.sync-progress-fill{height:100%;background:var(–acc);border-radius:2px;transition:width .3s}
.np-api-note{display:flex;align-items:flex-start;gap:10px;padding:12px 14px;background:var(–bb);border:1px solid var(–bbrd);border-radius:8px;margin-bottom:14px;font-size:12px;color:var(–blue)}
.api-code{background:var(–s3);border:1px solid var(–brd);border-radius:6px;padding:10px 14px;font-family:var(–mono);font-size:11.5px;color:var(–tx);margin:8px 0;overflow-x:auto;white-space:pre}
/* RESPONSIVE */
@media(max-width:900px){
.nav-menu{display:none}
.data-table-wrap{display:none}
.cards-wrap{display:flex}
.drawer{width:100vw}
.toolbar-actions .btn-lbl{display:none}
}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
</style>

</head>
