function getAddrBadge(s){
  const ACTIVE=['unformed','formed','deferred','priority'];
  if(!ACTIVE.includes(s.status))return '';
  const same=SHIPMENTS.filter(x=>x.cId===s.cId&&ACTIVE.includes(x.status));
  if(same.length<=1)return '';
  const addrs=[...new Set(same.map(x=>x.addr))];
  if(addrs.length<=1)return '';
  const idx=addrs.indexOf(s.addr)+1;
  return `<span class="addr-badge" title="Відправка ${idx} з ${addrs.length} незавершених адрес цього клієнта">📍${idx}/${addrs.length}</span>`;
}

