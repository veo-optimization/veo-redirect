// NP API SYNC (demo simulation + real API structure)
// ═══════════════════════════════════════════════
const NP_STATUS_MAP={
  '1':null,          // Нове відправлення — не змінюємо
  '2':null,          // Видалено
  '3':null,          // Прийнято
  '4':'transit',     // В дорозі
  '5':'transit',     // Прийнято в місті призначення
  '6':'transit',     // Вантаж прямує у відділення
  '7':'transit',     // Прибуло у відділення
  '8':null,          // Затримка
  '9':'received',    // Отримано одержувачем ✅
  '10':'returned',   // Відмова/повернення
  '11':null,         // Відправлення не існує
  '14':null,         // Відкликано
};

let syncTimer=null;
let syncCountdown=15*60; // 15 хвилин
let lastSyncTime=null;
let syncRunning=false;

function startSyncTimer(){
  if(syncTimer)clearInterval(syncTimer);
  syncCountdown=15*60;
  syncTimer=setInterval(()=>{
    syncCountdown--;
    updateSyncBar();
    if(syncCountdown<=0){runNPSync();}
  },1000);
  updateSyncBar();
}

function updateSyncBar(){
  const dot=document.getElementById('syncDot');
  const dot2=document.getElementById('syncDot2');
  const txt=document.getElementById('syncText');
  const det=document.getElementById('syncDetails');
  const pillTxt=document.getElementById('syncPillTxt');
  const active=SHIPMENTS.filter(s=>s.status==='sent'||s.status==='transit').length;
  if(syncRunning){
    [dot,dot2].forEach(d=>{if(d)d.className='sync-dot pulse';});
    if(txt)txt.textContent='Синхронізація…';
    if(pillTxt)pillTxt.textContent='…';
    return;
  }
  const mins=Math.floor(syncCountdown/60);
  const secs=(syncCountdown%60).toString().padStart(2,'0');
  if(active===0){
    [dot,dot2].forEach(d=>{if(d){d.className='sync-dot idle';}});
    if(txt)txt.textContent='Немає активних відправок';
    if(pillTxt)pillTxt.textContent='НП';
    if(det)det.textContent='Активних відправок: 0';
  } else {
    [dot,dot2].forEach(d=>{if(d){d.className='sync-dot';d.style.background='var(--green)';}});
    if(txt)txt.textContent=`НП: ${mins}:${secs} до перевірки`;
    if(pillTxt)pillTxt.textContent=`${mins}:${secs}`;
    if(det)det.textContent=`Відстежується: ${active} · ${lastSyncTime?'Остання: '+lastSyncTime:'Ще не перевірялось'}`;
  }
}

// Реальний запит до НП API (потребує бекенд-проксі через CORS)
async function fetchNPStatusReal(ttns){
  // В продакшн замінити на власний бекенд-ендпоінт:
  // const res = await fetch('/api/np-track', {
  //   method: 'POST',
  //   body: JSON.stringify({ ttns }),
  //   headers: { 'Content-Type': 'application/json' }
  // });
  // return await res.json();

  // DEMO: симуляція відповіді НП
  return ttns.map(ttn=>{
    const s=SHIPMENTS.find(x=>x.ttn===ttn);
    if(!s)return {ttn,statusCode:'11',status:'Відправлення не знайдено'};
    // simulate realistic progression
    const daysAgo=(Date.now()-new Date(s.date))/(1000*60*60*24);
    let code;
    if(s.status==='sent'){code=daysAgo>0.5?'4':'3';}
    else if(s.status==='transit'){
      if(daysAgo>3)code='9';       // отримано через 3+ дні
      else if(daysAgo>2)code='7';  // у відділенні
      else code='4';
    } else code='4';
    return {ttn,statusCode:code,status:{
      '3':'Прийнято відправником','4':'Відправлення в дорозі',
      '7':'Прибуло у відділення','9':'Отримано одержувачем','11':'Не знайдено'
    }[code]||'—'};
  });
}

async function runNPSync(){
  if(syncRunning)return;
  const targets=SHIPMENTS.filter(s=>s.status==='sent'||s.status==='transit');
  if(!targets.length){showToast('Немає відправок для відстеження','');return;}
  syncRunning=true;
  const btn=document.getElementById('syncBtn');
  if(btn){btn.disabled=true;btn.textContent='Перевірка…';}
  const prog=document.getElementById('syncProgress');
  const fill=document.getElementById('syncFill');
  if(prog)prog.style.display='block';
  updateSyncBar();

  // Animate progress bar
  let pct=0;
  const progInterval=setInterval(()=>{
    pct=Math.min(pct+4,90);
    if(fill)fill.style.width=pct+'%';
  },50);

  // Simulate network delay
  await new Promise(r=>setTimeout(r,1400));

  const ttns=targets.map(s=>s.ttn).filter(Boolean);
  const results=await fetchNPStatusReal(ttns);

  clearInterval(progInterval);
  if(fill)fill.style.width='100%';

  let updated=0;
  results.forEach(r=>{
    const newStatus=NP_STATUS_MAP[r.statusCode];
    if(!newStatus)return;
    const s=SHIPMENTS.find(x=>x.ttn===r.ttn);
    if(!s||s.status===newStatus)return;
    const prevStatus=s.status;
    s.status=newStatus;
    if(newStatus==='received'&&s.payStatus==='cod_pending'){
      s.payStatus='paid';
    }
    // map status code 7 to 'arrived' notification
    const notifKey=r.statusCode==='7'?'arrived':newStatus;
    notifyClientTelegram(s.id,notifKey);
    updated++;
  });

  await new Promise(r=>setTimeout(r,300));
  if(prog)prog.style.display='none';
  if(fill)fill.style.width='0%';

  syncRunning=false;
  lastSyncTime=new Date().toLocaleTimeString('uk-UA',{hour:'2-digit',minute:'2-digit'});
  syncCountdown=15*60;
  if(btn){btn.disabled=false;btn.innerHTML='<svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 12a9 9 0 009-9 9 9 0 019 9 9 9 0 01-9 9"/><path d="M3 12l3-3m-3 3l3 3"/></svg> Перевірити зараз';}

  if(updated>0){
    updateCounts();applyFilters();
    showToast(`НП API: оновлено ${updated} відправок ✓`,'success');
  } else {
    showToast(`НП API: змін немає (${targets.length} відправок перевірено)`,'');
  }
  updateSyncBar();
}

