// ═══════════════════════════════════════════════
// GROUP BY CLIENT SORT
// ═══════════════════════════════════════════════
function applyGroupSort(data){
  if(!groupByClient)return data;
  const GROUPABLE=['unformed','formed','deferred','priority'];
  // split: groupable vs not
  const groupable=data.filter(s=>GROUPABLE.includes(s.status));
  const rest=data.filter(s=>!GROUPABLE.includes(s.status));
  // group groupable by client
  const groups={};
  groupable.forEach(s=>{if(!groups[s.cId])groups[s.cId]=[];groups[s.cId].push(s);});
  const sortedGroups=Object.values(groups).sort((a,b)=>{
    const maxA=Math.max(...a.map(s=>new Date(s.date)));
    const maxB=Math.max(...b.map(s=>new Date(s.date)));
    return maxB-maxA;
  });
  return [...sortedGroups.flat(),...rest];
}

