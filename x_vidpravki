function populateClientFilter(){
  const sel=document.getElementById('fClient');
  const cur=sel.value;
  sel.innerHTML='<option value="">Всі клієнти</option>';
  // unique clients that have shipments
  const cIds=[...new Set(SHIPMENTS.map(s=>s.cId))].sort((a,b)=>CLIENTS[a].name.localeCompare(CLIENTS[b].name,'uk'));
  cIds.forEach(cId=>{
    const opt=document.createElement('option');
    opt.value=cId;opt.textContent=CLIENTS[cId].name;
    sel.appendChild(opt);
  });
  if(cur)sel.value=cur;
}

function clearFilters(){
  document.getElementById('srch').value='';
  document.getElementById('fClient').value='';
  document.getElementById('fStatus').value='';
  document.getElementById('fDate').value='';
  applyFilters();
}

function openHelp(){openModal('helpModal');}

function applyFilters(){
  const q=document.getElementById('srch').value.toLowerCase().trim();
  const cf=chipClientVal||document.getElementById('fClient').value;
  const sf=document.getElementById('fStatus').value;
  const df=chipDateVal||document.getElementById('fDate').value;
  const now=new Date();

  // show/hide clear button
  const hasFilter=q||cf||sf||df;
  const clrBtn=document.getElementById('clearFiltersBtn');
  if(clrBtn)clrBtn.style.display=hasFilter?'inline-flex':'none';

  filteredData=SHIPMENTS.filter(s=>{
    const cl=CLIENTS[s.cId];
    if(activeTab==='priority'){if(!priorityIds.has(s.id))return false;}
    else if(activeTab!=='all'&&s.status!==activeTab)return false;
    if(sf&&s.status!==sf)return false;
    if(cf&&s.cId!==cf)return false;
    if(q){
      const h=(cl.name+s.id+(s.ttn||'')+s.addr).toLowerCase();
      if(!h.includes(q))return false;
    }
    if(df){
      const d=new Date(s.date);
      if(df==='today'&&d.toDateString()!==now.toDateString())return false;
      if(df==='week'){const w=new Date(now);w.setDate(now.getDate()-7);if(d<w)return false;}
      if(df==='month'){const m=new Date(now);m.setMonth(now.getMonth()-1);if(d<m)return false;}
    }
    return true;
  });

  const ord={priority:-1,unformed:0,formed:1,sent:2,transit:3,deferred:4,received:5,returned:6,ignored:7};
  filteredData.sort((a,b)=>{
    const pa=priorityIds.has(a.id)?0:1,pb=priorityIds.has(b.id)?0:1;
    if(pa!==pb)return pa-pb;
    const so=(ord[a.status]??9)-(ord[b.status]??9);
    if(so!==0)return so;
    return new Date(b.date)-new Date(a.date);
  });
  if(groupByClient)filteredData=applyGroupSort(filteredData);

  renderTable();renderCards();renderSummary();
  document.getElementById('emptySt').style.display=filteredData.length?'none':'block';
}

